<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:minWidth="280dp">

    <TextView
        android:id="@+id/dialog_add_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dialog_add_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="@string/dialog_add_hint"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_add_name"
        android:textSize="14sp"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/dialog_add_name_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/dialog_field_background"
        android:hint="@string/dialog_add_name_hint"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_add_time"
        android:textSize="14sp"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/dialog_add_time_spinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/dialog_field_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_add_till_when"
        android:textSize="14sp"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/dialog_add_till_when_spinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/dialog_field_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_add_color"
        android:textSize="14sp"
        android:textStyle="bold" />
    <Spinner
        android:id="@+id/dialog_add_color_spinner"
        android:layout_width="wrap_content"
        android:minWidth="120dp"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/dialog_field_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />
</LinearLayout>
