<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".FirstFragment">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_have_medime"
        style="@style/Widget.MediMeApp.BubbleButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:minHeight="64dp"
        android:paddingVertical="16dp"
        android:text="I have MediMe"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@id/button_no_medime"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintWidth_max="400dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_no_medime"
        style="@style/Widget.MediMeApp.BubbleButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:minHeight="64dp"
        android:paddingVertical="16dp"
        android:text="I don't have MediMe"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_have_medime"
        app:layout_constraintWidth_max="400dp" />
</androidx.constraintlayout.widget.ConstraintLayout>